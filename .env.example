# Copy this file to .env in the backend/ directory and adjust as needed

# Server
HOST=127.0.0.1
PORT=8000

# Workspace — where decompiled files, DB, and certs are stored
WORKSPACE_DIR=~/.apkanalysis

# Tool paths (defaults look in tools/ directory relative to project root)
JAVA_PATH=java
# APKTOOL_JAR=tools/apktool.jar
# JADX_PATH=tools/jadx/bin/jadx
# ADB_PATH=tools/platform-tools/adb

# Proxy
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
