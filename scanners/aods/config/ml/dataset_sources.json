      "total_samples": "25,000+"
    },
    "phase_2_expanded": {
      "datasets": ["OWApp", "DiverseVul"],
      "description": "Large-scale function-level training",
      "total_samples": "350,000+"
    },
    "phase_3_malware": {
      "datasets": ["MH-1M", "Drebin", "AMD", "PRAGuard", "Kharon", "CICMalDroid"],
      "description": "Malware detection and classification training",
      "total_samples": "1,400,000+",
      "notes": "MH-1M is the largest and most recent (2025)"
    },
    "phase_4_optional": {
      "datasets": ["AndroZoo", "AndroMalShare"],
      "description": "Massive scale datasets requiring registration/API keys",
      "total_samples": "15,000,000+",
      "access_notes": {
        "AndroZoo": "API key required - https://androzoo.uni.lu/access",
        "AndroMalShare": "Research registration required"
      }
    }
  },
  "recommended_order": [
