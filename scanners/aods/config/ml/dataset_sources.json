        "harvard_dataverse": "https://doi.org/10.7910/DVN/LLHEGN"
      },
      "notes": "GitHub has metadata/code. Full 400GB+ dataset at Harvard Dataverse."
    },
    {
      "name": "Drebin",
      "type": "manual",
      "url": "https://www.sec.tu-bs.de/~danarp/drebin/",
      "subdir": "drebin",
      "include_ext": [".apk", ".csv", ".txt"],
      "description": "5,560 malware samples from 179 families (2010-2012). Classic benchmark dataset.",
      "access": "Request access via website form",
      "samples": 5560,
      "families": 179
    },
    {
      "name": "AMD",
      "type": "manual",
      "url": "http://amd.arguslab.org",
      "subdir": "amd",
      "include_ext": [".apk"],
      "description": "Android Malware Dataset: 24,553 samples across 135 varieties and 71 families (2010-2016)",
      "access": "Registration required at amd.arguslab.org",
      "samples": 24553,
      "families": 71
    },
    {
      "name": "PRAGuard",
      "type": "manual",
      "url": "http://pralab.diee.unica.it/en/AndroidPRAGuardDataset",
      "subdir": "praguard",
      "include_ext": [".apk"],
      "description": "10,479 obfuscated malware samples from MalGenome and Contagio. Tests evasion resistance.",
      "access": "Download from PRALab website",
      "samples": 10479,
      "obfuscation_techniques": ["trivial", "string_encryption", "reflection", "class_encryption"]
    },
    {
      "name": "Kharon",
