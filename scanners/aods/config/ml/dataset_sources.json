      "include_ext": [".csv", ".json", ".py", ".parquet"],
      "description": "1.34M Android malware samples with rich metadata (2025). Full data at Harvard Dataverse.",
      "data_urls": {
        "github": "https://github.com/Malware-Hunter/MH-1M",
