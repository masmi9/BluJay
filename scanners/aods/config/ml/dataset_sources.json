    },
    {
      "name": "OWApp",
      "type": "git",
      "url": "https://github.com/Mobile-IoT-Security-Lab/OWApp-Benchmarking-Suite.git",
      "subdir": "owapp",
      "include_ext": [".apk", ".json"],
      "description": "Framework for benchmarking mobile security tools"
    },
    {
      "name": "DiverseVul",
      "type": "git",
      "url": "https://github.com/wagner-group/diversevul.git",
      "subdir": "diversevul",
      "include_ext": [".json", ".csv", ".py"],
      "description": "Dataset of 349K vulnerable/non-vulnerable functions"
    },
    {
      "name": "MH-1M",
      "type": "git",
      "url": "https://github.com/Malware-Hunter/MH-1M.git",
